{
    "compilerOptions": {
        "strict": true,
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "types": ["vite/client", "vike-react", "@types/bun"],
        "noEmit": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "paths": {
            "~/*": ["./src/*"],
            "@surrealdb/docs-search-common/*": ["./search/src/*"]
        }
    },
    "include": ["**/*", ".vike-content-collection/**/*"],
    "exclude": ["dist", "node_modules", "src-old"]
}
