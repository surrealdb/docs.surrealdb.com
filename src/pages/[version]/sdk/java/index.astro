---
import RenderDoc from '@src/components/RenderDoc.astro';
import {
    SDK_JAVA_VERSIONS,
    type SdkJavaVersion,
} from '@src/util/sdkJavaVersion';

export const getStaticPaths = async () => {
    return SDK_JAVA_VERSIONS.filter((v) => v !== 'latest').map((version) => ({
        params: { version },
    }));
};

const { version } = Astro.params;

if (!version || !SDK_JAVA_VERSIONS.includes(version as SdkJavaVersion)) {
    return Astro.redirect('/docs/sdk/java', 301);
}

const docName = version === '1.x' ? 'sdk-java-1x' : 'sdk-java';
---

<RenderDoc doc={docName as any} slug="index" />
